.env
Backend/.env

# --- Python ---
__pycache__/
*.pyc
venv/
backend/venv/

# --- Node / React ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# --- OS junk ---
.DS_Store
Thumbs.db